{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Monitor",
  "colors": {
    "primary": "#4F46E5",
    "light": "#818CF8",
    "dark": "#3730A3"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/monitors",
              "features/status-pages",
              "features/incidents",
              "features/alert-channels",
              "features/api-keys"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/aevrHQ/monitor",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@aevr.space"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://monitor.aevr.space"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/aevrHQ/monitor"
    }
  }
}
